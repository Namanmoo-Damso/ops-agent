# ===================================================================
# OPS Agent Environment Configuration
# ===================================================================
# 이 파일을 agent.env로 복사하여 사용하세요
# cp agent.env.example agent.env

# >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> 환경별 변경 필요
LIVEKIT_URL=wss://livekit.sodam.store
API_BASE_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379
AGENT_NAME=voice-agent-1  # 개발: voice-agent-N (N=인스턴스번호), 프로덕션: voice-agent
# <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<< 환경별 변경 필요


# ===================================================================
# [필수] LiveKit Connection
# ===================================================================
LIVEKIT_API_KEY=<YOUR_LIVEKIT_API_KEY>
LIVEKIT_API_SECRET=<YOUR_LIVEKIT_API_SECRET>


# ===================================================================
# [필수] AWS Credentials
# ===================================================================
# Used for: Bedrock LLM, Polly TTS (STT는 custom provider 사용 시 불필요)
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>
AWS_DEFAULT_REGION=ap-northeast-2


# ===================================================================
# [필수] API Authentication
# ===================================================================
API_INTERNAL_TOKEN=<YOUR_API_INTERNAL_TOKEN>


# ===================================================================
# Agent Basic Settings
# ===================================================================
AGENT_TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR


# ===================================================================
# STT Provider Configuration
# ===================================================================
# Provider options: aws | custom
STT_PROVIDER=custom
# STT 서버 URL (custom 사용 시 필수)
STT_SERVER_URL=http://localhost:8000


# ===================================================================
# LLM Provider Configuration
# ===================================================================
# Provider: aws | openai | ollama
#   aws:    AWS Bedrock (Claude)
#   openai: OpenAI-compatible API (vLLM, OpenAI, etc.)
#   ollama: Local Ollama server
LLM_PROVIDER=aws

# Model names by provider:
#   aws:    global.anthropic.claude-haiku-4-5-20251001-v1:0 (recommended)
#   openai: Qwen/Qwen3-8B-AWQ (vLLM), gpt-4o-mini (OpenAI)
#   ollama: exaone3.5:7.8b, llama3.1
LLM_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# Temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# Base URL (openai/ollama only)
# LLM_BASE_URL=http://localhost:8000/v1   # vLLM
# LLM_BASE_URL=http://localhost:11434/v1  # Ollama

# API Key (openai only, optional for vLLM)
# LLM_API_KEY=EMPTY


# ===================================================================
# TTS Provider Configuration
# ===================================================================
# Provider: aws | ai_server
TTS_PROVIDER=aws

# AWS Polly Settings (when TTS_PROVIDER=aws)
AWS_POLLY_VOICE=Seoyeon        # Korean: Seoyeon | English: Joanna, Matthew
AWS_POLLY_ENGINE=generative    # generative (best), neural, standard

# AI Server Settings (when TTS_PROVIDER=ai_server)
# AI_SERVER_URL=http://localhost:8001
# AI_SERVER_VOICE=F2            # Supertonic voices: F1, F2, M1, M2


# ===================================================================
# MCP (Model Context Protocol) Settings
# ===================================================================
MCP_ENABLED=false

# KMA (Korea Meteorological Administration) - Weather API
# Get your API key from https://apihub.kma.go.kr/
# KMA_MCP_URL=http://localhost:8002/sse
# KMA_AUTH_KEY=<YOUR_KMA_AUTH_KEY>


# ===================================================================
# RAG Configuration (Optional - uses defaults if not set)
# ===================================================================
# RAG_MEMORY_SIMILARITY_THRESHOLD=0.35
# RAG_CHILD_CHUNK_SIZE=200
# RAG_CHILD_CHUNK_OVERLAP=50
# RAG_WINDOW_CONTEXT_CHARS=150


# ===================================================================
# AI Server Configuration (로컬 GPU 모델 서버 사용 시)
# ===================================================================
# AI_SERVER_URL=http://localhost:8001
# WHISPER_MODEL=large-v3-turbo
# TTS_VOICE=F2
