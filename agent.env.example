# ===================================================================
# OPS Agent Environment Configuration
# ===================================================================
# 이 파일을 agent.env로 복사하여 사용하세요
# cp agent.env.example agent.env

# ===================================================================
# [필수] AWS Credentials (Polly TTS)
# ===================================================================
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>
AWS_DEFAULT_REGION=ap-northeast-2

# ===================================================================
# [필수] LiveKit Connection
# ===================================================================
LIVEKIT_URL=wss://livekit.sodam.store
LIVEKIT_API_KEY=<YOUR_LIVEKIT_API_KEY>
LIVEKIT_API_SECRET=<YOUR_LIVEKIT_API_SECRET>

# ===================================================================
# [필수] Redis
# ===================================================================
REDIS_URL=redis://localhost:6379

# ===================================================================
# [필수] API Server
# ===================================================================
API_BASE_URL=https://2.sodam.store
API_INTERNAL_TOKEN=<YOUR_API_INTERNAL_TOKEN>

# ===================================================================
# Agent Settings
# ===================================================================
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR
AGENT_NAME=voice-agent-1  # 개발: voice-agent-N, 프로덕션: voice-agent
AGENT_TIMEZONE=Asia/Seoul

# ===================================================================
# MCP (날씨 API)
# ===================================================================
KMA_AUTH_KEY=<YOUR_KMA_AUTH_KEY>
KMA_MCP_URL=http://localhost:8002/sse
MCP_ENABLED=true

# ===================================================================
# LLM Settings (vLLM + Qwen3-8B AWQ)
# ===================================================================
# Provider: openai (vLLM) | aws (Bedrock) | ollama
LLM_PROVIDER=openai
LLM_MODEL=Qwen/Qwen3-8B-AWQ
LLM_BASE_URL=http://localhost:8000/v1
LLM_TEMPERATURE=0.7

# ===================================================================
# STT Settings (AI Server + Whisper GPU)
# ===================================================================
# Provider: external (AI Server) | aws (Transcribe)
STT_PROVIDER=external
AI_SERVER_URL=http://localhost:8001

# ===================================================================
# TTS Settings (AWS Polly)
# ===================================================================
# Provider: aws (Polly) | external (AI Server)
TTS_PROVIDER=aws
TTS_VOICE=Seoyeon  # Korean: Seoyeon

# ===================================================================
# Token Management
# ===================================================================
MAX_CONTEXT_ITEMS=20  # 컨텍스트 아이템 최대 개수 (토큰 오버플로우 방지)
