# ===================================================================
# OPS Agent Environment Configuration
# ===================================================================
# 이 파일을 agent.env로 복사하여 사용하세요
# cp agent.env.example agent.env

# >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>> 환경별 변경 필요
LIVEKIT_URL=wss://livekit.sodam.store
API_BASE_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379
AGENT_NAME=voice-agent-1  # 개발: voice-agent-N (N=인스턴스번호), 프로덕션: voice-agent
# <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<< 환경별 변경 필요


# ===================================================================
# [필수] LiveKit Connection
# ===================================================================
LIVEKIT_API_KEY=<YOUR_LIVEKIT_API_KEY>
LIVEKIT_API_SECRET=<YOUR_LIVEKIT_API_SECRET>


# ===================================================================
# [필수] AWS Credentials
# ===================================================================
# Used for: Polly TTS, (선택) Bedrock LLM, Transcribe STT
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_KEY>
AWS_DEFAULT_REGION=ap-northeast-2


# ===================================================================
# [필수] API Authentication
# ===================================================================
API_INTERNAL_TOKEN=<YOUR_API_INTERNAL_TOKEN>


# ===================================================================
# Agent Basic Settings
# ===================================================================
AGENT_TIMEZONE=Asia/Seoul
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR


# ===================================================================
# LLM Provider Configuration (권장: vLLM + Qwen3)
# ===================================================================
# Provider: aws | openai | ollama
#   aws:    AWS Bedrock (Claude)
#   openai: OpenAI-compatible API (vLLM) - 권장
#   ollama: Local Ollama server
LLM_PROVIDER=openai

# Model names by provider:
#   aws:    global.anthropic.claude-haiku-4-5-20251001-v1:0
#   openai: Qwen/Qwen3-8B-AWQ (vLLM 권장)
#   ollama: exaone3.5:7.8b, llama3.1
LLM_MODEL=Qwen/Qwen3-8B-AWQ

# Temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# Base URL (openai/ollama only)
LLM_BASE_URL=http://localhost:8000/v1   # vLLM (docker-compose 기본)
# LLM_BASE_URL=http://localhost:11434/v1  # Ollama

# API Key (openai only, optional for vLLM)
# LLM_API_KEY=EMPTY


# ===================================================================
# STT Provider Configuration (권장: AI Server + Whisper GPU)
# ===================================================================
# Provider: aws | external
#   aws:      AWS Transcribe
#   external: AI Server (Whisper GPU) - 권장
STT_PROVIDER=external

# AI Server URL (external 사용 시 필수)
AI_SERVER_URL=http://localhost:8001


# ===================================================================
# TTS Provider Configuration (권장: AWS Polly)
# ===================================================================
# Provider: aws | external
#   aws:      AWS Polly - 권장
#   external: AI Server (Supertonic)
TTS_PROVIDER=aws
TTS_VOICE=Seoyeon  # Korean: Seoyeon | English: Joanna, Matthew

# AI Server TTS (when TTS_PROVIDER=external)
# TTS_VOICE=F2  # Supertonic voices: F1-F5, M1-M5


# ===================================================================
# MCP (Model Context Protocol) Settings - 날씨 API
# ===================================================================
MCP_ENABLED=true
KMA_MCP_URL=http://localhost:8002/sse

# KMA (Korea Meteorological Administration) API Key
# Get your API key from https://apihub.kma.go.kr/
KMA_AUTH_KEY=<YOUR_KMA_AUTH_KEY>


# ===================================================================
# RAG Configuration (Optional - uses defaults if not set)
# ===================================================================
# RAG_MEMORY_SIMILARITY_THRESHOLD=0.35
# RAG_CHILD_CHUNK_SIZE=200
# RAG_CHILD_CHUNK_OVERLAP=50
# RAG_WINDOW_CONTEXT_CHARS=150


# ===================================================================
# Token Management
# ===================================================================
# 컨텍스트 아이템 최대 개수 (토큰 오버플로우 방지)
MAX_CONTEXT_ITEMS=20
