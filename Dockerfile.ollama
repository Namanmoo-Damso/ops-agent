# Ollama with pre-downloaded models
# This Dockerfile creates an Ollama image with models baked in for faster startup

FROM ollama/ollama:latest

# Install curl for preloading
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Environment variables for model configuration
ENV OLLAMA_HOST=0.0.0.0:11434
ENV OLLAMA_KEEP_ALIVE=24h

# Download models at build time
# Start ollama in background, pull model, then stop
RUN ollama serve & \
    pid=$! && \
    sleep 5 && \
    ollama pull llama3.1 && \
    kill $pid

# Create startup script that preloads model
RUN cat > /start.sh <<'SCRIPT'
#!/bin/bash
set -e

# Start ollama in background
ollama serve &
OLLAMA_PID=$!

# Wait for ollama to be ready
echo "Waiting for Ollama to start..."
for i in {1..30}; do
  if curl -s http://localhost:11434/api/tags >/dev/null 2>&1; then
    echo "Ollama is ready"
    break
  fi
  sleep 1
done

# Preload model into memory (MUST complete before continuing)
echo "Preloading llama3.1 model (this may take 60+ seconds)..."
curl -s http://localhost:11434/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '{"model":"llama3.1","messages":[{"role":"user","content":"Hi"}],"stream":false}' \
  > /dev/null
echo "Model preloaded successfully - ready for requests"

# Wait for ollama process
wait $OLLAMA_PID
SCRIPT

RUN chmod +x /start.sh

# Expose Ollama API port
EXPOSE 11434

# Override ENTRYPOINT and use bash to run startup script
ENTRYPOINT ["/bin/bash"]
CMD ["/start.sh"]
