# AWS Credentials (for Transcribe, Polly, Bedrock)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=ap-northeast-2

# LiveKit connection
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# API Server
API_BASE_URL=http://localhost:8080

# Internal API Authentication (MUST match ops-api API_INTERNAL_TOKEN)
API_INTERNAL_TOKEN=your-secret-internal-token

# Agent routing (instance-specific)
AGENT_NAME=voice-agent

# Redis (optional)
REDIS_URL=redis://localhost:6379

# RAG Parent-Child Configuration (Optional - uses defaults if not set)
RAG_MEMORY_SIMILARITY_THRESHOLD=0.35    # Similarity threshold for memory recall (0.0-1.0)
RAG_CHILD_CHUNK_SIZE=200                # Child chunk size (must match ops-api)
RAG_CHILD_CHUNK_OVERLAP=50              # Child chunk overlap (must match ops-api)
RAG_WINDOW_CONTEXT_CHARS=150            # Window size for snippet extraction (must match ops-api)

# Agent Timezone
AGENT_TIMEZONE=Asia/Seoul               # Timezone for relative time display

# Optional
LOG_LEVEL=INFO
